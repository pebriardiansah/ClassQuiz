{\n  "quiz_meta": {\n    "title": "Skrining Psikologis - Calon Dokter\",\n    "subtitle": "Sistem Penilaian Awal Karyawan Rumah Sakit\",\n    "target_position": "Dokter\",\n    "duration_minutes": 30,\n    "created_date": "2026-07-22\",\n    "language": "id\",\n    "total_questions": 75,\n    "description": "Tes screening komprehensif untuk evaluasi kepribadian, stress resilience, dan emotional intelligence calon dokter. Format Likert 1-5.\"\n  },\n  \n  "questions": [\n    {\n      "q_id": 1,\n      "section": "Big Five Personality\",\n      "dimension": "Openness\",\n      "text": "Saya suka mencoba hal-hal baru dan tidak takut mengambil risiko yang terukur\",\n      "reverse": false\n    },\n    {\n      "q_id": 2,\n      "section": "Big Five Personality\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya termasuk orang yang sangat terorganisir dan detail dalam menyelesaikan pekerjaan\",\n      "reverse": false\n    },\n    {\n      "q_id": 3,\n      "section": "Big Five Personality\",\n      "dimension": "Extraversion\",\n      "text": "Saya suka bergaul dengan banyak orang dan sering menjadi pusat perhatian\",\n      "reverse": false\n    },\n    {\n      "q_id": 4,\n      "section": "Big Five Personality\",\n      "dimension": "Agreeableness\",\n      "text": "Saya mudah berempati dan peduli dengan kesejahteraan orang lain\",\n      "reverse": false\n    },\n    {\n      "q_id": 5,\n      "section": "Big Five Personality\",\n      "dimension": "Neuroticism\",\n      "text": "Saya sering merasa cemas atau khawatir tentang hal-hal kecil\",\n      "reverse": true\n    },\n    {\n      "q_id": 6,\n      "section": "Big Five Personality\",\n      "dimension": "Openness\",\n      "text": "Saya tertarik mempelajari teori-teori baru dan penelitian terbaru di bidang medis\",\n      "reverse": false\n    },\n    {\n      "q_id": 7,\n      "section": "Big Five Personality\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya selalu mengecek pekerjaan saya dua kali untuk memastikan tidak ada kesalahan\",\n      "reverse": false\n    },\n    {\n      "q_id": 8,\n      "section": "Big Five Personality\",\n      "dimension": "Extraversion\",\n      "text": "Saya lebih suka bekerja sendiri daripada dalam tim\",\n      "reverse": true\n    },\n    {\n      "q_id": 9,\n      "section": "Big Five Personality\",\n      "dimension": "Agreeableness\",\n      "text": "Saya bersedia mengorbankan kepentingan pribadi saya untuk membantu orang lain\",\n      "reverse": false\n    },\n    {\n      "q_id": 10,\n      "section": "Big Five Personality\",\n      "dimension": "Neuroticism\",\n      "text": "Ketika menghadapi masalah, saya tetap tenang dan mencari solusi rasional\",\n      "reverse": true\n    },\n    {\n      "q_id": 11,\n      "section": "Big Five Personality\",\n      "dimension": "Openness\",\n      "text": "Saya terbuka terhadap pendapat berbeda dari kolega meskipun berbeda dengan pendapat saya\",\n      "reverse": false\n    },\n    {\n      "q_id": 12,\n      "section": "Big Five Personality\",\n      "dimension": "Conscientiousness\",\n      "text": "Deadline adalah hal yang tidak bisa saya anggap remeh, saya selalu selesai tepat waktu\",\n      "reverse": false\n    },\n    {\n      "q_id": 13,\n      "section": "Big Five Personality\",\n      "dimension": "Extraversion\",\n      "text": "Saya nyaman mengkomunikasikan diagnosis kompleks kepada pasien dan keluarganya\",\n      "reverse": false\n    },\n    {\n      "q_id": 14,\n      "section": "Big Five Personality\",\n      "dimension": "Agreeableness\",\n      "text": "Saya merasa kasihan dengan pasien yang menderita dan itu mempengaruhi pekerjaan saya\",\n      "reverse": false\n    },\n    {\n      "q_id": 15,\n      "section": "Big Five Personality\",\n      "dimension": "Neuroticism\",\n      "text": "Saya cenderung menyalahkan diri sendiri ketika ada hal yang tidak berjalan sempurna\",\n      "reverse": true\n    },\n    {\n      "q_id": 16,\n      "section": "Big Five Personality\",\n      "dimension": "Openness\",\n      "text": "Saya tidak tertarik dengan prosedur medis yang belum mainstream atau tidak traditional\",\n      "reverse": true\n    },\n    {\n      "q_id": 17,\n      "section": "Big Five Personality\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya sering lupa membuat dokumentasi lengkap untuk setiap pasien\",\n      "reverse": true\n    },\n    {\n      "q_id": 18,\n      "section": "Big Five Personality\",\n      "dimension": "Extraversion\",\n      "text": "Saya merasa energik ketika berinteraksi dengan banyak pasien dalam satu hari\",\n      "reverse": false\n    },\n    {\n      "q_id": 19,\n      "section": "Big Five Personality\",\n      "dimension": "Agreeableness\",\n      "text": "Kadang saya terlalu keras atau blak-blakan dengan pasien saat memberikan kabar buruk\",\n      "reverse": true\n    },\n    {\n      "q_id": 20,\n      "section": "Big Five Personality\",\n      "dimension": "Neuroticism\",\n      "text": "Saya mudah tersinggung dengan kritik dari sesama dokter atau atasan\",\n      "reverse": true\n    },\n    {\n      "q_id": 21,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "StressHandling\",\n      "text": "Ketika menghadapi situasi darurat medis yang kompleks, saya dapat fokus dan mengambil keputusan dengan cepat\",\n      "reverse": false\n    },\n    {\n      "q_id": 22,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "Resilience\",\n      "text": "Saya mampu bekerja lembur atau dalam kondisi lelah tanpa performa menurun signifikan\",\n      "reverse": false\n    },\n    {\n      "q_id": 23,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "StressHandling\",\n      "text": "Saya memiliki cara efektif untuk mengatasi stress (olahraga, meditasi, hobi, dll)\",\n      "reverse": false\n    },\n    {\n      "q_id": 24,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "Resilience\",\n      "text": "Ketika mengalami kegagalan dalam perawatan pasien, saya bisa belajar dari kesalahan dan move on\",\n      "reverse": false\n    },\n    {\n      "q_id": 25,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "StressHandling\",\n      "text": "Saya merasa overwhelmed atau burnout dengan beban kerja medis\",\n      "reverse": true\n    },\n    {\n      "q_id": 26,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "Resilience\",\n      "text": "Saya optimis bahwa saya bisa menghadapi tantangan di dunia medis\",\n      "reverse": false\n    },\n    {\n      "q_id": 27,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "StressHandling\",\n      "text": "Ketika mengalami hari yang sangat sibuk, saya tetap dapat bersikap empati kepada pasien\",\n      "reverse": false\n    },\n    {\n      "q_id": 28,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "Resilience\",\n      "text": "Saya percaya diri dapat menangani komplikasi medis yang tidak terduga\",\n      "reverse": false\n    },\n    {\n      "q_id": 29,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "StressHandling\",\n      "text": "Saya sering membawa stress kerja ke rumah dan sulit untuk relaks\",\n      "reverse": true\n    },\n    {\n      "q_id": 30,\n      "section": "Stress Resilience & Coping\",\n      "dimension": "Resilience\",\n      "text": "Saya memiliki support system yang baik (keluarga, teman, kolega) untuk menghadapi tantangan\",\n      "reverse": false\n    },\n    {\n      "q_id": 31,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "SelfAwareness\",\n      "text": "Saya memahami dengan baik kekuatan dan kelemahan diri saya sebagai dokter\",\n      "reverse": false\n    },\n    {\n      "q_id": 32,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "SelfRegulation\",\n      "text": "Saya dapat mengendalikan emosi negatif saya (marah, frustrasi) dalam situasi kerja yang sulit\",\n      "reverse": false\n    },\n    {\n      "q_id": 33,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "Empathy\",\n      "text": "Saya dapat memahami dan merasakan apa yang dialami pasien dan keluarganya\",\n      "reverse": false\n    },\n    {\n      "q_id": 34,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "SocialSkills\",\n      "text": "Saya mudah berkomunikasi dan membangun hubungan baik dengan pasien dan keluarganya\",\n      "reverse": false\n    },\n    {\n      "q_id": 35,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "Motivation\",\n      "text": "Motivasi utama saya menjadi dokter adalah keinginan untuk membantu dan melayani pasien\",\n      "reverse": false\n    },\n    {\n      "q_id": 36,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "Empathy\",\n      "text": "Ketika pasien merasa takut atau sedih, saya tahu apa yang harus saya katakan untuk menenangkan mereka\",\n      "reverse": false\n    },\n    {\n      "q_id": 37,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "SelfRegulation\",\n      "text": "Saya sering defensif ketika mendapat kritik dari kolega atau supervisor\",\n      "reverse": true\n    },\n    {\n      "q_id": 38,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "SocialSkills\",\n      "text": "Saya mampu menjelaskan kondisi medis kompleks dengan cara yang mudah dipahami pasien awam\",\n      "reverse": false\n    },\n    {\n      "q_id": 39,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "Empathy\",\n      "text": "Saya sering kehabisan waktu untuk mendengarkan keluh kesah pasien karena terlalu banyak pasien\",\n      "reverse": true\n    },\n    {\n      "q_id": 40,\n      "section": "Emotional Intelligence & Patient Care\",\n      "dimension": "Motivation\",\n      "text": "Saya tertarik dengan aspek finansial pekerjaan dokter lebih dari pada melayani pasien\",\n      "reverse": true\n    },\n    {\n      "q_id": 41,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Openness\",\n      "text": "Saya aktif mencari pelatihan dan sertifikasi untuk meningkatkan kompetensi medis saya\",\n      "reverse": false\n    },\n    {\n      "q_id": 42,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya mengikuti protokol dan guideline medis dengan ketat setiap saat\",\n      "reverse": false\n    },\n    {\n      "q_id": 43,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Extraversion\",\n      "text": "Saya adalah tipe dokter yang aktif berinteraksi dan menjalin rapport dengan pasien\",\n      "reverse": false\n    },\n    {\n      "q_id": 44,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Agreeableness\",\n      "text": "Dalam tim medis, saya lebih suka mendengarkan masukan dari rekan sejawat\",\n      "reverse": false\n    },\n    {\n      "q_id": 45,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Neuroticism\",\n      "text": "Saya merasa gugup atau tidak percaya diri ketika harus menangani kasus yang sulit\",\n      "reverse": true\n    },\n    {\n      "q_id": 46,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Openness\",\n      "text": "Saya terbuka dengan menggunakan teknologi dan metode treatment terbaru\",\n      "reverse": false\n    },\n    {\n      "q_id": 47,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya selalu mengupdate catatan pasien dengan informasi yang akurat dan lengkap\",\n      "reverse": false\n    },\n    {\n      "q_id": 48,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Extraversion\",\n      "text": "Saya menikmati saat harus memberikan presentasi atau berbicara di depan umum\",\n      "reverse": false\n    },\n    {\n      "q_id": 49,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Agreeableness\",\n      "text": "Saya mudah maaf dan tidak menyimpan dendam terhadap rekan kerja\",\n      "reverse": false\n    },\n    {\n      "q_id": 50,\n      "section": "Big Five Personality (Extended)\",\n      "dimension": "Neuroticism\",\n      "text": "Saya dapat tetap fokus bahkan dalam situasi dengan banyak gangguan atau tekanan\",\n      "reverse": true\n    },\n    {\n      "q_id": 51,\n      "section": "Stress Resilience & Coping (Extended)\",\n      "dimension": "StressHandling\",\n      "text": "Saya tahu kapan saya perlu istirahat dan tidak takut untuk mengambil cuti ketika diperlukan\",\n      "reverse": false\n    },\n    {\n      "q_id": 52,\n      "section": "Stress Resilience & Coping (Extended)\",\n      "dimension": "Resilience\",\n      "text": "Saya bangkit dengan cepat setelah mengalami kegagalan atau kesalahan diagnosis\",\n      "reverse": false\n    },\n    {\n      "q_id": 53,\n      "section": "Stress Resilience & Coping (Extended)\",\n      "dimension": "StressHandling\",\n      "text": "Saya memiliki hobi atau aktivitas di luar pekerjaan yang membantu saya relaks\",\n      "reverse": false\n    },\n    {\n      "q_id": 54,\n      "section": "Stress Resilience & Coping (Extended)\",\n      "dimension": "Resilience\",\n      "text": "Saya bisa menghadapi bad news atau informasi negatif dengan tetap profesional dan optimis\",\n      "reverse": false\n    },\n    {\n      "q_id": 55,\n      "section": "Stress Resilience & Coping (Extended)\",\n      "dimension": "StressHandling\",\n      "text": "Saya berbicara dengan teman atau keluarga ketika merasa tertekan oleh pekerjaan\",\n      "reverse": false\n    },\n    {\n      "q_id": 56,\n      "section": "Stress Resilience & Coping (Extended)\",\n      "dimension": "Resilience\",\n      "text": "Saya percaya bahwa experience dan tantangan membuat saya dokter yang lebih baik\",\n      "reverse": false\n    },\n    {\n      "q_id": 57,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "SelfAwareness\",\n      "text": "Saya sadar tentang bias personal atau prejudice saya dan berusaha mengatasinya\",\n      "reverse": false\n    },\n    {\n      "q_id": 58,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "SelfRegulation\",\n      "text": "Saya tidak menyalahkan pasien atau keluarganya ketika merasa frustrasi\",\n      "reverse": false\n    },\n    {\n      "q_id": 59,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "Empathy\",\n      "text": "Saya memahami bahwa penyakit bukan hanya aspek fisik tapi juga psikis dan sosial pasien\",\n      "reverse": false\n    },\n    {\n      "q_id": 60,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "SocialSkills\",\n      "text": "Saya mampu mengatasi konflik dengan pasien atau keluarga dengan cara yang tenang dan profesional\",\n      "reverse": false\n    },\n    {\n      "q_id": 61,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "Motivation\",\n      "text": "Saya merasa puas ketika saya bisa membantu pasien sembuh atau meningkat kondisinya\",\n      "reverse": false\n    },\n    {\n      "q_id": 62,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "Empathy\",\n      "text": "Saya sensitif terhadap kebutuhan emosional pasien, terutama yang sedang dalam kondisi krisis\",\n      "reverse": false\n    },\n    {\n      "q_id": 63,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "SocialSkills\",\n      "text": "Saya bisa beradaptasi dengan berbagai macam tipe pasien dan latar belakang budaya\",\n      "reverse": false\n    },\n    {\n      "q_id": 64,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "SelfRegulation\",\n      "text": "Saya tidak membawa masalah personal ke ruangan pasien atau clinic\",\n      "reverse": false\n    },\n    {\n      "q_id": 65,\n      "section": "Emotional Intelligence & Patient Care (Extended)\",\n      "dimension": "Motivation\",\n      "text": "Saya ingin terus belajar dan berkembang sebagai dokter sepanjang karir saya\",\n      "reverse": false\n    },\n    {\n      "q_id": 66,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya meluangkan waktu untuk berpikir sebelum membuat keputusan medis yang penting\",\n      "reverse": false\n    },\n    {\n      "q_id": 67,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Openness\",\n      "text": "Saya mencari second opinion atau konsultasi dengan rekan ketika tidak yakin tentang diagnosis\",\n      "reverse": false\n    },\n    {\n      "q_id": 68,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Agreeableness\",\n      "text": "Saya menghargai masukan dari tim medis lain (perawat, fisioterapis, dll) dalam membuat keputusan\",\n      "reverse": false\n    },\n    {\n      "q_id": 69,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya selalu mengikuti evidence-based practice dalam memberikan treatment\",\n      "reverse": false\n    },\n    {\n      "q_id": 70,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Neuroticism\",\n      "text": "Saya tidak takut bertanya kepada supervisor ketika ada hal yang tidak saya mengerti\",\n      "reverse": true\n    },\n    {\n      "q_id": 71,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Openness\",\n      "text": "Saya terbuka untuk mengakui kesalahan saya dan belajar dari experience\",\n      "reverse": false\n    },\n    {\n      "q_id": 72,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Conscientiousness\",\n      "text": "Saya selalu follow-up dengan pasien untuk memastikan treatment berjalan dengan baik\",\n      "reverse": false\n    },\n    {\n      "q_id": 73,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Agreeableness\",\n      "text": "Saya menjelaskan rencana treatment secara jelas sehingga pasien dapat membuat informed decision\",\n      "reverse": false\n    },\n    {\n      "q_id": 74,\n      "section": "Clinical Competence & Decision Making\",\n      "dimension": "Openness\",\n      "text": "Saya aktif mengikuti perkembangan ilmu pengetahuan medis terbaru melalui journal atau conference\",\n      "reverse": false\n    },\n    {\n      "q_id\": 75,\n      "section": "Clinical Competence & Decision Making\",\n      \"dimension\": \"Conscientiousness\",\n      \"text\": \"Saya tidak pernah terburu-buru dalam membuat keputusan medis meskipun waktu terbatas\",\n      \"reverse\": false\n    }\n  ],\n\n  \"scoring_guide\": {\n    \"DOKTER\": {\n      \"Conscientiousness\": {\n        \"min\": 4.0,\n        \"ideal\": 4.5,\n        \"weight\": 0.25,\n        \"importance\": \"CRITICAL\"\n      },\n      \"Openness\": {\n        \"min\": 3.8,\n        \"ideal\": 4.2,\n        \"weight\": 0.20,\n        \"importance\": \"HIGH\"\n      },\n      \"Agreeableness\": {\n        \"min\": 3.5,\n        \"ideal\": 4.0,\n        \"weight\": 0.15,\n        \"importance\": \"MEDIUM\"\n      },\n      \"Emotional_Stability\": {\n        \"min\": 3.5,\n        \"ideal\": 4.0,\n        \"weight\": 0.15,\n        \"importance\": \"HIGH\"\n      },\n      \"EQ_Overall\": {\n        \"min\": 3.5,\n        \"ideal\": 4.2,\n        \"weight\": 0.15,\n        \"importance\": \"HIGH\"\n      },\n      \"Stress_Resilience\": {\n        \"min\": 3.2,\n        \"ideal\": 4.0,\n        \"weight\": 0.10,\n        \"importance\": \"MEDIUM\"\n      }\n    }\n  },\n\n  \"red_flags\": {\n    \"neuroticism_high\": {\n      \"threshold\": 4.2,\n      \"severity\": \"HIGH\",\n      \"message\": \"Tingkat neuroticism tinggi - cenderung cemas/khawatir\"\n    },\n    \"conscientiousness_low\": {\n      \"threshold\": 3.0,\n      \"severity\": \"CRITICAL\",\n      \"message\": \"Conscientiousness rendah - risiko kesalahan medis\"\n    },\n    \"empathy_low\": {\n      \"threshold\": 3.0,\n      \"severity\": \"HIGH\",\n      \"message\": \"Empati rendah - kurang sesuai untuk patient care\"\n    },\n    \"stress_resilience_low\": {\n      \"threshold\": 3.0,\n      \"severity\": \"HIGH\",\n      \"message\": \"Stress resilience rendah - tidak siap untuk emergency\"\n    },\n    \"emotional_stability_low\": {\n      \"threshold\": 2.8,\n      \"severity\": \"CRITICAL\",\n      \"message\": \"Emotional stability rendah - tidak siap untuk emergency situations\"\n    }\n  },\n\n  \"recommendations\": {\n    \"PROCEED\": {\n      \"overall_score_min\": 3.8,\n      \"red_flags_max\": 0,\n      \"message\": \"Kandidat menunjukkan profil psikologis yang sesuai untuk posisi dokter. Lanjutkan ke tahap interview teknis.\",\n      \"action\": \"Interview Tahap 2 - Medical Knowledge & Clinical Skills\"\n    },\n    \"FURTHER_ASSESSMENT\": {\n      \"overall_score_min\": 3.4,\n      \"red_flags_max\": 1,\n      \"message\": \"Ada beberapa aspek yang perlu dikonfirmasi lebih lanjut. HR disarankan melakukan interview mendalam.\",\n      \"action\": \"Verification Interview dengan HR\"\n    },\n    \"CAUTION\": {\n      \"overall_score_max\": 3.3,\n      \"red_flags_min\": 2,\n      \"message\": \"Ada indikasi signifikan yang perlu dievaluasi lebih lanjut. Pertimbangkan rujuk ke psikolog profesional.\",\n      \"action\": \"Tinjau Ulang atau Konsultasi Psikolog Profesional sebelum hiring\"\n    }\n  },\n\n  \"likert_scale\": {\n    \"1\": \"Sangat Tidak Setuju / Tidak Pernah\",\n    \"2\": \"Tidak Setuju / Jarang\",\n    \"3\": \"Netral / Kadang-kadang\",\n    \"4\": \"Setuju / Sering\",\n    \"5\": \"Sangat Setuju / Selalu\"\n  },\n\n  \"metadata\": {\n    \"total_questions\": 75,\n    \"sections\": {\n      \"Big Five Personality\": 20,\n      \"Big Five Personality (Extended)\": 10,\n      \"Stress Resilience & Coping\": 10,\n      \"Stress Resilience & Coping (Extended)\": 6,\n      \"Emotional Intelligence & Patient Care\": 10,\n      \"Emotional Intelligence & Patient Care (Extended)\": 9\n    },\n    \"dimensions\": [\n      \"Openness\",\n      \"Conscientiousness\",\n      \"Extraversion\",\n      \"Agreeableness\",\n      \"Neuroticism\",\n      \"StressHandling\",\n      \"Resilience\",\n      \"SelfAwareness\",\n      \"SelfRegulation\",\n      \"Empathy\",\n      \"SocialSkills\",\n      \"Motivation\"\n    ],\n    \"version\": \"1.0\",\n    \"last_updated\": \"2026-07-22\",\n    \"language\": \"Indonesian (Bahasa Indonesia)\"\n  }\n}\n